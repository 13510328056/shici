# ============================================================
# PoetrySpace (古诗词文化互动平台) — 环境变量配置
# ============================================================
# 复制此文件为 .env 并修改其中的值：
#   cp .env.example .env
# ============================================================

# ---- 运行环境 ----
# development | staging | production
ENV=development

# ---- 数据库 ----
# 开发环境默认使用 SQLite（无需 Docker）：
# DATABASE_URL=sqlite+aiosqlite:///./poetry_space_dev.db
#
# 生产环境使用 PostgreSQL + PostGIS：
# DATABASE_URL=postgresql+asyncpg://poetry:YOUR_PASSWORD@localhost:5432/poetry_space
DATABASE_URL=sqlite+aiosqlite:///./poetry_space_dev.db

# ---- 搜索引擎（可选）----
ELASTICSEARCH_URL=http://localhost:9200

# ---- Redis（可选，用于缓存和速率限制）----
# 格式：redis://[:PASSWORD]@HOST:PORT/DB
REDIS_URL=redis://localhost:6379/0

# ---- JWT / API 安全 ----
# ⚠️ 生产环境必须改为一个长的随机字符串！！！
# 可用以下命令生成：openssl rand -hex 32
SECRET_KEY=dev-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---- CORS ----
# 逗号分隔的允许跨域来源
CORS_ORIGINS=http://localhost:15173

# ---- 时空围栏参数 ----
GEO_FENCE_RADIUS_KM=80
TIME_TOLERANCE_YEARS=1

# ---- 性能指标阈值 ----
MAP_RENDER_THRESHOLD_MS=1000
SEARCH_RESPONSE_THRESHOLD_MS=500
